# Database
DB_PASSWORD=changeme_secure_password
DATABASE_URL=postgresql+asyncpg://linew:changeme_secure_password@postgres:5432/linew

# Redis
REDIS_URL=redis://redis:6379/0

# AI Gateway (vertex-key.com - OpenAI compatible)
AI_GATEWAY_URL=https://vertex-key.com
AI_GATEWAY_KEY=your-vertex-key-here

# AI Model Configuration
AI_WRITER_MODEL=gpt-4o
AI_LIGHT_MODEL=gpt-4o-mini

# WordPress
WP_URL=http://localhost/news
WP_USERNAME=admin
WP_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# FlareSolverr (Cloudflare bypass)
FLARESOLVERR_URL=http://flaresolverr:8191/v1

# Application
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ENVIRONMENT=development
LOG_LEVEL=info

# TimesFM (Prediction) - MPS for Apple Silicon
TIMESFM_DEVICE=mps

# Flask (for dev server)
FLASK_ENV=development

# Distribution Channels
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@linews_vn
TELEGRAM_CHANNEL_ENABLED=true

FACEBOOK_PAGE_ID=your_page_id
FACEBOOK_PAGE_ACCESS_TOKEN=your_long_lived_token
FACEBOOK_APP_ID=your_app_id
FACEBOOK_APP_SECRET=your_app_secret
FACEBOOK_ENABLED=true

TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret
TWITTER_ENABLED=true

# Newsletter
NEWSLETTER_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=linews@gmail.com
SMTP_PASSWORD=your_app_password
NEWSLETTER_FROM_NAME=Linews
NEWSLETTER_FROM_EMAIL=linews@gmail.com

# Analytics & SEO
GA_MEASUREMENT_ID=G-XXXXXXXXXX
SITE_URL=https://litimez.ai
SITE_NAME=Linews

# CORS - comma-separated list of allowed origins (leave empty for development)
# Example: CORS_ORIGINS=https://example.com,https://app.example.com
CORS_ORIGINS=

# Linew Data Path - directory for linew-data volume (bind mount)
# Default: /Users/tmnhat/Backup-Linew
LINEW_DATA_PATH=/Users/tmnhat/Backup-Linew

# ═══════════════════════════════════════════════════════════════
# Prediction V2 - External API Keys (CHỈ CRYPTO & US STOCK)
# ═══════════════════════════════════════════════════════════════

# FRED API - Federal Reserve Economic Data
# Đăng ký: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Finnhub API - Financial news, events, earnings calendar
# Đăng ký: https://finnhub.io
FINNHUB_API_KEY=

# Fincept API (optional) - Alternative financial data
FINCEPT_API_KEY=

# Lunarcrush API - Crypto social sentiment (Galaxy Score)
# Đăng ký: https://lunarcrush.com/developers
# FREE tier: 100 req/day
LUNARCRUSH_API_KEY=

# ═══════════════════════════════════════════════════════════════
# Prediction V2 - Feature Flags
# ═══════════════════════════════════════════════════════════════
PREDICTION_ENABLE_FUNDAMENTAL=true
PREDICTION_ENABLE_MACRO=true
PREDICTION_ENABLE_ONCHAIN=true
PREDICTION_ENABLE_EVENTS=true

# ═══════════════════════════════════════════════════════════════
# Prediction V3 - Feature Flags (NEW)
# ═══════════════════════════════════════════════════════════════
PREDICTION_ENABLE_MULTI_AGENT=true
PREDICTION_ENABLE_ADAPTIVE_WEIGHTS=true
PREDICTION_ENABLE_REGIME_DETECTION=true
PREDICTION_ENABLE_MTF=true
PREDICTION_ENABLE_OPTIONS=true
PREDICTION_ENABLE_SOCIAL=true
PREDICTION_ENABLE_CORRELATION=true
PREDICTION_CALIBRATION_ENABLED=true
